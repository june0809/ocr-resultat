# -----------------------------------------------------------------------------
# Cles d'API des clients (tenants). SPEC §8.
#
# Le service ne stocke JAMAIS les cles en clair : on garde leur hash SHA-256.
# Format : hash:label , plusieurs entrees separees par des virgules.
# Le label sert au rate-limiting par tenant et aux logs (jamais la cle brute).
#
# Genere une paire (cle brute + hash) avec :  npm run keygen
# Donne la cle BRUTE (sk_...) au client (The Circle) ; mets le HASH ici.
# -----------------------------------------------------------------------------
API_KEYS="<sha256_hash>:the-circle"

# Rate limit : nombre de requetes autorisees par fenetre, par cle. SPEC §8 (~60/min).
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW_SEC="60"

# Seuil de confiance en dessous duquel un pseudo declenche un warning. SPEC §5.3.
CONFIDENCE_WARN_THRESHOLD="0.90"

# Confiance globale minimale exploitable : en dessous -> 422 unreadable_scoreboard.
# Volontairement bas : tout passe par la validation humaine (§9), le 422 ne rejette
# qu'un scoreboard vraiment illisible (pas un match aux pseudos stylises).
CONFIDENCE_MIN_USABLE="0.30"

# Origine autorisee pour la page d'upload (CORS). SPEC §8. Vide = pas de CORS.
ALLOWED_ORIGIN="http://localhost:3000"
